{
    "version": "0.2.0",
    "configurations": [

        // ─── Java ───────────────────────────────────────────────
        {
            "name": "Java: Run Current File",
            "type": "java",
            "request": "launch",
            "mainClass": "${fileBasenameNoExtension}",
            "classPaths": ["${workspaceFolder}/JLite"]
        },

        // ─── Python (build system) ───────────────────────────────
        {
            "name": "Python: build.py",
            "type": "python",
            "request": "launch",
            "program": "${workspaceFolder}/build.py",
            "console": "integratedTerminal"
        },
        {
            "name": "Python: MetaBuild.py",
            "type": "python",
            "request": "launch",
            "program": "${workspaceFolder}/MetaBuild.py",
            "console": "integratedTerminal"
        }
    ]
}
